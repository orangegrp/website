---
import '../styles/global.css';
import favicon from '$lib/assets/favicon.svg';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = '332 — Order332',
	description = 'A new kind of platform. Explore our blog, projects, and more.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="theme-color" content="#0d0d0d" />
		<link rel="preload" href="/fonts/VT323-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preconnect" href="https://avatars.githubusercontent.com" crossorigin />
		<link rel="preload" href="/polygon.svg" as="image" type="image/svg+xml" fetchpriority="high" />
		<link rel="icon" href={favicon.src} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://order332.com/og-image.png" />
		<meta property="og:url" content="https://order332.com" />
		<meta property="og:site_name" content="332" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://order332.com/og-image.png" />
	</head>
	<body>
		<div class="min-h-screen">
			<slot />
		</div>
	</body>
</html>
