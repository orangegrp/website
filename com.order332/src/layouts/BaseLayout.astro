---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	/**
	 * Path to the OG image relative to /public, e.g. "/og/about.png".
	 * If omitted, auto-derived from the current route:
	 *   /          → /og/index.png
	 *   /about     → /og/about.png
	 *   /foo/bar   → /og/bar.png        (last path segment)
	 *   /blog/*    → /og/blog.png        (all blog posts share one)
	 * Fallback when no file exists: /og/default.png
	 */
	ogImage?: string;
}

const {
	title = '332 — Order332',
	description = '332 Discord community hub — occasional blog posts plus the usual invite-only disclaimers.',
	ogImage,
} = Astro.props;

function deriveOgImage(pathname: string): string {
	if (pathname === '/') return '/og/index.png';
	const segments = pathname.replace(/\/$/, '').split('/').filter(Boolean);
	// All blog post pages share one image
	if (segments[0] === 'blog' && segments.length > 1) return '/og/blog.png';
	// Use last path segment as filename
	return `/og/${segments[segments.length - 1]}.png`;
}

const siteOrigin = Astro.url.origin;
const resolvedOgImage = siteOrigin + (ogImage ?? deriveOgImage(Astro.url.pathname));
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="theme-color" content="#0d0d0d" />
		<link rel="preload" href="/fonts/VT323-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preconnect" href="https://avatars.githubusercontent.com" crossorigin />
		<link rel="preload" href="/polygon.svg" as="image" type="image/svg+xml" fetchpriority="high" />
		<link rel="icon" href="/polygon.svg" type="image/svg+xml" />
		<link rel="canonical" href={canonicalUrl} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="332" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
	</head>
	<body>
		<div class="min-h-screen">
			<slot />
		</div>
	</body>
</html>
