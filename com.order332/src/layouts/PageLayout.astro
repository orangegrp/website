---
import BaseLayout from './BaseLayout.astro';
import Navbar from '$lib/components/elements/navbar/navbar.svelte';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
	<Navbar client:load />
	<slot />
</BaseLayout>
