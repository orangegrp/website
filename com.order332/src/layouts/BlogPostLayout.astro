---
import PageLayout from './PageLayout.astro';

interface Props {
	title: string;
	description: string;
	date: Date;
	author?: string;
	tags?: string[];
}

const { title, description, date, author = '332', tags = [] } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(date);

// Utterances uses non-DOM script attrs (repo, issue-term, …); Astro's ScriptHTMLAttributes omit them.
const utterancesScriptAttrs = {
	repo: 'orangegrp/website',
	'issue-term': 'pathname',
	label: 'blog-comments',
	theme: 'github-dark',
	crossorigin: 'anonymous',
	async: true,
} as any;
---

<PageLayout title={`${title} — 332`} description={description} ogImage="/og/blog.png">
	<div class="page-root relative min-h-screen px-4 pb-24 pt-32">
		<div class="dot-pattern pointer-events-none absolute inset-0" aria-hidden="true"></div>

		<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
			<div
				class="absolute -left-[10%] top-[5%] h-[600px] w-[600px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.9 0 0 / 6%), transparent 65%); filter: blur(100px);"
			></div>
			<div
				class="absolute -right-[5%] top-[30%] h-[500px] w-[500px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.8 0 0 / 5%), transparent 65%); filter: blur(80px);"
			></div>
		</div>

		<div class="relative z-10 mx-auto max-w-2xl">
			<!-- Breadcrumb -->
			<nav class="mb-8" aria-label="Breadcrumb">
				<a
					href="/blog"
					class="glass-nav-link inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm tracking-wider text-muted-foreground transition-all hover:text-foreground no-underline"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m15 18-6-6 6-6"/>
					</svg>
					Back to Blog
				</a>
			</nav>

			<!-- Post header -->
			<header class="glass-card mb-10 px-8 py-10 sm:px-12">
				<div class="mb-4 flex flex-wrap items-center gap-3 text-xs tracking-widest text-muted-foreground uppercase">
					<time datetime={date.toISOString()}>{formattedDate}</time>
					{author && (
						<>
							<span class="opacity-30">·</span>
							<span>{author}</span>
						</>
					)}
				</div>

				<h1 class="mb-4 text-3xl leading-tight tracking-wider text-foreground sm:text-4xl">
					{title}
				</h1>

				<p class="text-base leading-relaxed text-muted-foreground">
					{description}
				</p>

				{tags.length > 0 && (
					<div class="mt-6 flex flex-wrap gap-2">
						{tags.map(tag => (
							<span class="glass-button rounded-full px-3 py-0.5 text-xs tracking-wider text-muted-foreground">
								{tag}
							</span>
						))}
					</div>
				)}
			</header>

			<!-- Post body -->
			<article class="prose-332">
				<slot />
			</article>

			<section class="blog-comments mt-12" aria-label="Comments" data-utterances-section>
				<div data-utterances-root class="blog-comments-widget">
					<script is:inline src="https://utteranc.es/client.js" {...utterancesScriptAttrs}></script>
				</div>
				<p
					class="blog-comments-fallback hidden text-sm leading-relaxed text-muted-foreground"
					data-utterances-fallback
					role="status"
					aria-live="polite"
					hidden
				>
					Comments could not load. This is often caused by a privacy extension or strict tracking protection
					blocking GitHub. Try allowlisting this site or opening the page in another browser.
				</p>
				<script is:inline>
					(function () {
						var root = document.querySelector('[data-utterances-root]');
						var fb = document.querySelector('[data-utterances-fallback]');
						if (!root || !fb) return;
						var done = false;
						var tid;
						function success() {
							if (done) return;
							done = true;
							if (tid) clearTimeout(tid);
							window.removeEventListener('message', onMsg);
						}
						function onMsg(e) {
							if (e.origin !== 'https://utteranc.es') return;
							var d = e.data;
							if (d && d.type === 'resize' && typeof d.height === 'number' && d.height > 0) success();
						}
						function fail() {
							if (done) return;
							done = true;
							window.removeEventListener('message', onMsg);
							root.classList.add('hidden');
							root.setAttribute('aria-hidden', 'true');
							fb.classList.remove('hidden');
							fb.removeAttribute('hidden');
						}
						window.addEventListener('message', onMsg);
						function start() {
							if (done) return;
							tid = setTimeout(fail, 11000);
						}
						if (document.readyState === 'complete') start();
						else window.addEventListener('load', start);
					})();
				</script>
			</section>

			<!-- Footer nav -->
			<div class="mt-16 border-t border-white/5 pt-8">
				<a
					href="/blog"
					class="glass-nav-link inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm tracking-wider text-muted-foreground transition-all hover:text-foreground no-underline"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m15 18-6-6 6-6"/>
					</svg>
					All posts
				</a>
			</div>
		</div>
	</div>
</PageLayout>

<style>
	:global(.blog-comments .utterances) {
		max-width: 100%;
	}

	:global(.blog-comments .utterances-frame) {
		width: 100%;
	}

	.blog-comments-fallback {
		margin-top: 0;
		max-width: 42rem;
	}

	.prose-332 {
		color: oklch(0.75 0 0);
		line-height: 1.8;
		font-size: 1.05rem;
	}

	.prose-332 :global(h1),
	.prose-332 :global(h2),
	.prose-332 :global(h3),
	.prose-332 :global(h4) {
		color: oklch(0.92 0 0);
		letter-spacing: 0.05em;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}

	.prose-332 :global(h1) {
		font-size: 2rem;
	}

	.prose-332 :global(h2) {
		font-size: 1.5rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid oklch(1 0 0 / 8%);
	}

	.prose-332 :global(h3) {
		font-size: 1.2rem;
	}

	.prose-332 :global(p) {
		margin-bottom: 1.25rem;
	}

	.prose-332 :global(a) {
		color: oklch(0.85 0 0);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: oklch(1 0 0 / 25%);
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}

	.prose-332 :global(a:hover) {
		color: oklch(0.95 0 0);
		text-decoration-color: oklch(1 0 0 / 55%);
	}

	.prose-332 :global(ul),
	.prose-332 :global(ol) {
		padding-left: 1.5rem;
		margin-bottom: 1.25rem;
	}

	.prose-332 :global(li) {
		margin-bottom: 0.4rem;
	}

	.prose-332 :global(ul li) {
		list-style-type: disc;
	}

	.prose-332 :global(ol li) {
		list-style-type: decimal;
	}

	.prose-332 :global(code) {
		background: var(--glass-bg-highlight);
		border-top: 1px solid var(--glass-border-top);
		border-left: 1px solid var(--glass-border-left);
		border-right: 1px solid var(--glass-border-right);
		border-bottom: 1px solid var(--glass-border-bottom-dark);
		border-radius: var(--glass-radius-sm);
		box-shadow: var(--glass-shadow-inset-sm);
		padding: 0.1em 0.35em;
		font-size: 0.9em;
		font-family: monospace;
		color: oklch(0.88 0 0);
	}

	.prose-332 :global(pre) {
		position: relative;
		background: var(--glass-bg-overlay);
		backdrop-filter: var(--glass-blur-lg);
		-webkit-backdrop-filter: var(--glass-blur-lg);
		border-top: 1px solid oklch(1 0 0 / 16%);
		border-left: 1px solid var(--glass-border-left);
		border-right: 1px solid var(--glass-border-faint);
		border-bottom: 1px solid oklch(1 0 0 / 4%);
		border-radius: var(--glass-radius-xl);
		box-shadow: var(--glass-shadow-card);
		padding: 1.25rem 1.5rem;
		overflow-x: auto;
		margin-bottom: 1.5rem;
	}

	.prose-332 :global(.pre-wrapper) {
		position: relative;
		margin-bottom: 1.5rem;
	}

	.prose-332 :global(.pre-wrapper pre) {
		margin-bottom: 0;
	}

	.prose-332 :global(.copy-btn) {
		position: absolute;
		top: 50%;
		right: 0.75rem;
		transform: translateY(-50%);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem;
		background: oklch(1 0 0 / 0%);
		border: 1px solid oklch(1 0 0 / 0%);
		border-radius: var(--glass-radius-sm);
		color: oklch(1 0 0 / 0%);
		cursor: pointer;
		transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	}

	.prose-332 :global(.pre-wrapper:hover .copy-btn) {
		background: var(--glass-bg-button);
		border-color: var(--glass-border-subtle);
		color: oklch(0.65 0 0);
	}

	.prose-332 :global(.copy-btn:hover) {
		background: var(--glass-bg-hover) !important;
		border-color: var(--glass-border-top) !important;
		color: oklch(0.85 0 0) !important;
	}

	.prose-332 :global(.copy-btn.copied) {
		color: oklch(0.75 0.15 145) !important;
		border-color: oklch(0.75 0.15 145 / 30%) !important;
	}

	/* ── Collapsed large codeblocks ─────────────────────────────────── */

	.prose-332 :global(.pre-wrapper.collapsed pre) {
		max-height: 16rem;
		overflow: hidden;
		mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
		-webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
	}

	.prose-332 :global(.expand-bar) {
		display: flex;
		align-items: center;
		justify-content: center;
		margin-top: -1px;
		padding: 0.5rem;
		cursor: pointer;
		background: none;
		border: none;
		width: 100%;
		color: oklch(0.5 0 0);
		font-size: 0.7rem;
		font-family: monospace;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		gap: 0.4rem;
		transition: color 0.2s ease;
	}

	.prose-332 :global(.expand-bar:hover) {
		color: oklch(0.75 0 0);
	}

	/* ── Code modal ─────────────────────────────────────────────────── */

	:global(.code-modal-backdrop) {
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: oklch(0 0 0 / 70%);
		backdrop-filter: blur(6px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	:global(.code-modal-backdrop.open) {
		opacity: 1;
	}

	:global(.code-modal) {
		position: relative;
		width: 100%;
		max-width: 56rem;
		max-height: 80vh;
		display: flex;
		flex-direction: column;
		background: var(--glass-bg-overlay);
		backdrop-filter: var(--glass-blur-lg);
		-webkit-backdrop-filter: var(--glass-blur-lg);
		border-top: 1px solid oklch(1 0 0 / 16%);
		border-left: 1px solid var(--glass-border-left);
		border-right: 1px solid var(--glass-border-faint);
		border-bottom: 1px solid oklch(1 0 0 / 4%);
		border-radius: var(--glass-radius-xl);
		box-shadow: var(--glass-shadow-card);
		transform: scale(0.97) translateY(8px);
		transition: transform 0.2s ease;
		overflow: hidden;
	}

	:global(.code-modal-backdrop.open .code-modal) {
		transform: scale(1) translateY(0);
	}

	:global(.code-modal-toolbar) {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		border-bottom: 1px solid oklch(1 0 0 / 8%);
		flex-shrink: 0;
	}

	:global(.code-modal-toolbar button) {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.3rem 0.65rem;
		background: var(--glass-bg-button);
		border-top: 1px solid var(--glass-border-top);
		border-left: 1px solid var(--glass-border-left);
		border-right: 1px solid var(--glass-border-faint);
		border-bottom: 1px solid var(--glass-border-bottom-dark);
		border-radius: var(--glass-radius-sm);
		color: oklch(0.65 0 0);
		font-size: 0.7rem;
		font-family: monospace;
		letter-spacing: 0.05em;
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease;
	}

	:global(.code-modal-toolbar button:hover) {
		background: var(--glass-bg-hover);
		color: oklch(0.85 0 0);
	}

	:global(.code-modal-toolbar button.copied) {
		color: oklch(0.75 0.15 145);
		border-color: oklch(0.75 0.15 145 / 30%);
	}

	:global(.code-modal-toolbar .close-btn) {
		margin-left: auto;
	}

	:global(.code-modal-body) {
		overflow: auto;
		padding: 1.25rem 1.5rem;
		flex: 1;
	}

	:global(.code-modal-body pre) {
		margin: 0;
		background: none !important;
		border: none !important;
		box-shadow: none !important;
		padding: 0 !important;
		border-radius: 0 !important;
		font-size: 0.875rem;
		line-height: 1.7;
	}

.prose-332 :global(pre code) {
		background: none;
		border: none;
		border-radius: 0;
		box-shadow: none;
		backdrop-filter: none;
		-webkit-backdrop-filter: none;
		padding: 0;
		font-size: 0.875rem;
	}

	.prose-332 :global(blockquote) {
		border-left: 2px solid oklch(1 0 0 / 20%);
		padding-left: 1rem;
		color: oklch(0.6 0 0);
		font-style: italic;
		margin: 1.5rem 0;
	}

	.prose-332 :global(hr) {
		border: none;
		border-top: 1px solid oklch(1 0 0 / 8%);
		margin: 2rem 0;
	}

	.prose-332 :global(strong) {
		color: oklch(0.88 0 0);
		font-weight: 600;
	}

	.prose-332 :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: 1.5rem;
	}

	.prose-332 :global(th) {
		border-bottom: 1px solid oklch(1 0 0 / 14%);
		padding: 0.5rem 0.75rem;
		text-align: left;
		color: oklch(0.88 0 0);
		font-size: 0.85rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.prose-332 :global(td) {
		border-bottom: 1px solid oklch(1 0 0 / 6%);
		padding: 0.5rem 0.75rem;
	}
</style>

<script>
	const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
	const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
	const downloadIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`;
	const expandIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>`;
	const closeIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;

	const COLLAPSE_THRESHOLD = 50;

	function makeCopyHandler(getText: () => string, btn: HTMLButtonElement) {
		btn.addEventListener('click', async () => {
			await navigator.clipboard.writeText(getText());
			btn.innerHTML = checkIcon + ' copied!';
			btn.classList.add('copied');
			setTimeout(() => {
				btn.innerHTML = copyIcon + ' copy';
				btn.classList.remove('copied');
			}, 2000);
		});
	}

	function openModal(code: string, preEl: HTMLElement) {
		const backdrop = document.createElement('div');
		backdrop.className = 'code-modal-backdrop';

		const modal = document.createElement('div');
		modal.className = 'code-modal';

		// Toolbar
		const toolbar = document.createElement('div');
		toolbar.className = 'code-modal-toolbar';

		const copyBtn = document.createElement('button');
		copyBtn.innerHTML = copyIcon + ' copy';
		makeCopyHandler(() => code, copyBtn);

		const dlBtn = document.createElement('button');
		dlBtn.innerHTML = downloadIcon + ' download';
		dlBtn.addEventListener('click', () => {
			const blob = new Blob([code], { type: 'text/plain' });
			const url = URL.createObjectURL(blob);
			const a = document.createElement('a');
			a.href = url;
			a.download = 'code.txt';
			a.click();
			URL.revokeObjectURL(url);
		});

		const closeBtn = document.createElement('button');
		closeBtn.className = 'close-btn';
		closeBtn.innerHTML = closeIcon;
		closeBtn.setAttribute('aria-label', 'Close');
		closeBtn.addEventListener('click', () => closeModal(backdrop));

		toolbar.append(copyBtn, dlBtn, closeBtn);

		// Body — clone the original highlighted pre
		const body = document.createElement('div');
		body.className = 'code-modal-body';
		const clonedPre = preEl.cloneNode(true) as HTMLElement;
		body.appendChild(clonedPre);

		modal.append(toolbar, body);
		backdrop.appendChild(modal);
		document.body.appendChild(backdrop);

		// Close on backdrop click
		backdrop.addEventListener('click', (e) => {
			if (e.target === backdrop) closeModal(backdrop);
		});

		// Close on Escape
		const onKey = (e: KeyboardEvent) => {
			if (e.key === 'Escape') { closeModal(backdrop); document.removeEventListener('keydown', onKey); }
		};
		document.addEventListener('keydown', onKey);

		requestAnimationFrame(() => backdrop.classList.add('open'));
	}

	function closeModal(backdrop: HTMLElement) {
		backdrop.classList.remove('open');
		backdrop.addEventListener('transitionend', () => backdrop.remove(), { once: true });
	}

	document.querySelectorAll('.prose-332 pre').forEach((pre) => {
		const wrapper = document.createElement('div');
		wrapper.className = 'pre-wrapper';
		pre.parentNode?.insertBefore(wrapper, pre);
		wrapper.appendChild(pre);

		const code = (pre as HTMLElement).querySelector('code')?.innerText ?? '';
		const lineCount = code.split('\n').length;
		const isLarge = lineCount > COLLAPSE_THRESHOLD;

		if (isLarge) {
			wrapper.classList.add('collapsed');

			const expandBar = document.createElement('button');
			expandBar.className = 'expand-bar';
			expandBar.innerHTML = expandIcon + ` expand (${lineCount} lines)`;
			expandBar.addEventListener('click', () => openModal(code, pre as HTMLElement));
			wrapper.appendChild(expandBar);
		}

		// Inline copy button (on wrapper, aligned to block edge)
		const btn = document.createElement('button') as HTMLButtonElement;
		btn.className = 'copy-btn';
		btn.innerHTML = copyIcon;
		btn.setAttribute('aria-label', 'Copy code');
		btn.addEventListener('click', async () => {
			await navigator.clipboard.writeText(code);
			btn.innerHTML = checkIcon;
			btn.classList.add('copied');
			setTimeout(() => {
				btn.innerHTML = copyIcon;
				btn.classList.remove('copied');
			}, 2000);
		});
		wrapper.appendChild(btn);
	});
</script>
