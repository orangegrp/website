---
import { getCollection, render } from 'astro:content';
import LegalLayout from '../../layouts/LegalLayout.astro';

const legalEntries = await getCollection('legal');

const findEntry = (candidates: string[]) =>
	legalEntries.find(entry =>
		candidates.some(candidate => {
			const id = entry.id ?? '';
			const filePath = entry.filePath ?? '';
			return (
				id === candidate ||
				id.endsWith(candidate) ||
				filePath.endsWith(candidate)
			);
		})
	);

const simpleEntry = findEntry([
	'privacy.simple',
	'privacy.simple.md',
	'privacy-simple',
	'privacy/simple',
]);
const fullEntry = findEntry([
	'privacy.full',
	'privacy.full.md',
	'privacy-full',
	'privacy/full',
]);

if (!simpleEntry || !fullEntry) {
	throw new Error('Missing legal content entries for Privacy Policy.');
}

const { Content: SimplePrivacy } = await render(simpleEntry);
const { Content: FullPrivacy } = await render(fullEntry);
---

<LegalLayout
	title="Privacy Policy"
	description="Read the plain-English version or the full legal policy."
	activeDoc="privacy"
>
	<SimplePrivacy slot="simple" />
	<FullPrivacy slot="full" />
</LegalLayout>
