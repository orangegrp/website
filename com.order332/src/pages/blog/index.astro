---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const anyPostHasTags = posts.some((p) => p.data.tags.length > 0);
---

<PageLayout
	title="Blog — 332"
	description="Rough drafts turned less rough: security notes, changelog banter, and whatever else cleared editing."
>
	<div class="page-root relative min-h-screen px-4 pb-32 pt-32">
		<div class="dot-pattern pointer-events-none absolute inset-0" aria-hidden="true"></div>

		<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
			<div
				class="absolute -left-[10%] top-[5%] h-[600px] w-[600px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.9 0 0 / 6%), transparent 65%); filter: blur(100px);"
			></div>
			<div
				class="absolute -right-[5%] bottom-[10%] h-[500px] w-[500px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.8 0 0 / 5%), transparent 65%); filter: blur(80px);"
			></div>
		</div>

		<div class="relative z-10 mx-auto max-w-4xl">
			<div class="mb-12">
				<h1 class="mb-4 text-4xl tracking-wider text-foreground sm:text-5xl">
					Blog
				</h1>
			</div>

			<div id="blog-filter-root" class="blog-filter-root">
				{posts.length > 0 && (
					<div class="blog-toolbar mb-10 flex flex-col gap-3 sm:gap-4">
						<div
							class="blog-search-panel glass-card rounded-2xl border border-border/50 bg-background/25 p-3 shadow-sm backdrop-blur-sm sm:p-4"
						>
							<div
								role="search"
								aria-label="Search and filter posts by text"
								class="blog-search-field flex flex-wrap items-center gap-x-3 gap-y-1.5 px-2.5 py-1 sm:gap-x-3 sm:px-3 sm:py-1.5"
							>
								<div
									id="blog-active-tags"
									class="blog-active-tags flex max-w-full shrink-0 flex-wrap items-center gap-2"
									aria-label="Active tag filters"
								></div>
								<div class="relative min-w-0 flex-1 basis-[min(100%,12rem)] sm:basis-64">
									<label for="blog-search" class="sr-only">
										Search posts
									</label>
									<span
										class="pointer-events-none absolute left-2.5 top-1/2 z-10 -translate-y-1/2 text-muted-foreground [&>svg]:opacity-80"
										aria-hidden="true"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											class="h-3.5 w-3.5 shrink-0"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<circle cx="11" cy="11" r="8" />
											<path d="m21 21-4.3-4.3" />
										</svg>
									</span>
									<input
										id="blog-search"
										type="text"
										inputmode="search"
										placeholder="Search posts…"
										autocomplete="off"
										enterkeyhint="search"
										class="blog-search h-8 w-full rounded-md border-0 bg-transparent py-0 pl-8 pr-3 text-sm leading-5 tracking-wide text-foreground placeholder:text-muted-foreground/80 outline-none transition-[color,background-color] focus:outline-none"
									/>
								</div>
							</div>
						</div>

						<div>
							<fieldset class="border-0 p-0">
								<div
									class={`flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4 ${anyPostHasTags ? 'sm:justify-between' : 'sm:justify-end'}`}
								>
									{anyPostHasTags && (
										<div class="flex min-w-0 flex-1 flex-wrap items-center gap-x-5 gap-y-2">
											<div
												id="blog-browse-tag-buttons"
												class="flex flex-wrap gap-2"
											></div>
											<button
												type="button"
												id="blog-tags-expand"
												class="hidden text-xs tracking-wider text-muted-foreground underline decoration-border/80 underline-offset-4 transition hover:text-foreground"
												aria-expanded="false"
											>
												Show all
											</button>
										</div>
									)}
									<div class="flex w-full shrink-0 justify-end sm:w-auto">
										<div
											id="blog-layout-dropdown"
											class="relative w-full sm:w-28"
										>
											<button
												type="button"
												id="blog-layout-trigger"
												class="blog-layout-trigger group glass-button flex h-8 min-h-8 w-full items-center justify-between gap-2 rounded-xl px-3 py-0 text-left text-sm leading-none tracking-wide text-muted-foreground outline-none transition hover:text-foreground focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/30"
												aria-expanded="false"
												aria-haspopup="listbox"
												aria-controls="blog-layout-menu"
												aria-label="Post layout"
											>
												<span id="blog-layout-value">Cards</span>
												<svg
													class="blog-layout-chevron h-4 w-4 shrink-0 text-muted-foreground transition-[transform,color] duration-200 group-hover:text-foreground"
													xmlns="http://www.w3.org/2000/svg"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
													aria-hidden="true"
												>
													<path d="m6 9 6 6 6-6" />
												</svg>
											</button>
											<div
												id="blog-layout-menu"
												class="blog-layout-menu glass-card absolute right-0 top-[calc(100%+0.375rem)] z-40 w-full min-w-0 rounded-xl p-1 shadow-lg"
												role="listbox"
												aria-labelledby="blog-layout-trigger"
											>
												<button
													type="button"
													class="blog-layout-option flex w-full items-center rounded-lg px-3 py-1.5 text-left text-sm tracking-wide text-muted-foreground outline-none transition-[background-color,color] duration-150 focus-visible:ring-2 focus-visible:ring-ring/30"
													role="option"
													data-layout="cards"
													aria-selected="true"
												>
													Cards
												</button>
												<button
													type="button"
													class="blog-layout-option flex w-full items-center rounded-lg px-3 py-1.5 text-left text-sm tracking-wide text-muted-foreground outline-none transition-[background-color,color] duration-150 focus-visible:ring-2 focus-visible:ring-ring/30"
													role="option"
													data-layout="list"
													aria-selected="false"
												>
													List
												</button>
											</div>
										</div>
									</div>
								</div>
							</fieldset>
						</div>
					</div>
				)}

				{posts.length > 0 ? (
					<>
						<p id="blog-filter-empty" class="mb-6 hidden text-sm text-muted-foreground" role="status">
							No posts match your search or selected tags.
						</p>
						<div
							id="blog-posts-container"
							class="blog-posts-grid grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
						>
							{posts.map(post => (
								<div
									class="blog-post-item"
									data-blog-tags={JSON.stringify(post.data.tags)}
									data-blog-title={post.data.title}
									data-blog-description={post.data.description}
								>
									<BlogCard
										title={post.data.title}
										description={post.data.description}
										date={post.data.date}
										slug={post.id}
										author={post.data.author}
										tags={post.data.tags}
									/>
								</div>
							))}
						</div>
					</>
				) : (
					<div class="glass-card rounded-2xl p-12 text-center">
						<p class="mb-2 text-xl tracking-wider text-foreground">Quiet for now.</p>
						<p class="text-sm text-muted-foreground">Posts will appear here when published.</p>
					</div>
				)}
			</div>
		</div>
	</div>

	<SiteFooter />

<style>
	/* Matches glass-system [data-slot="input"] / input-group focus treatment */
	.blog-search-field {
		border-radius: var(--glass-radius-lg);
		background: var(--glass-bg-input);
		border: 1px solid oklch(1 0 0 / 10%);
		backdrop-filter: var(--glass-blur-xs);
		box-shadow: inset 0 1px 0 oklch(1 0 0 / 6%);
		transition: background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
	}
	@media (prefers-reduced-motion: reduce) {
		.blog-search-field {
			transition: none;
		}
	}
	.blog-search-field:focus-within {
		background: oklch(1 0 0 / 5%);
		border-color: oklch(1 0 0 / 18%);
		box-shadow:
			inset 0 1px 0 oklch(1 0 0 / 8%),
			0 0 0 2px oklch(1 0 0 / 6%);
	}
	/* Plain text field avoids inconsistent native search decorations; role="search" is on the wrapper */
	.blog-search {
		-webkit-appearance: none;
		appearance: none;
		box-sizing: border-box;
	}
	@media (max-width: 767px) {
		.blog-search {
			font-size: 1rem;
		}
	}
	.blog-search-chip {
		box-shadow: inset 0 1px 0 oklch(1 0 0 / 8%);
	}
	#blog-active-tags.blog-active-tags:empty {
		display: none;
	}
	.blog-posts-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.blog-posts-list .blog-card {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		align-items: flex-start;
		column-gap: 1.25rem;
		row-gap: 0.75rem;
		padding: 1rem 1.25rem;
	}
	.blog-posts-list .blog-card:hover {
		transform: none;
	}
	.blog-posts-list .blog-card > div:first-child {
		margin-bottom: 0;
		flex: 0 0 auto;
		min-width: 7rem;
	}
	.blog-posts-list .blog-card h3 {
		margin-bottom: 0.25rem;
		flex: 1 1 12rem;
		min-width: 0;
	}
	.blog-posts-list .blog-card .blog-card-desc {
		flex: 1 0 100%;
		margin-bottom: 0;
		-webkit-line-clamp: 1;
	}
	.blog-posts-list .blog-card .blog-card-tag-row {
		flex: 1 1 auto;
		margin-bottom: 0;
	}
	.blog-posts-list .blog-card .blog-card-read {
		margin-left: auto;
		align-self: center;
	}
	@media (min-width: 640px) {
		.blog-posts-list .blog-card {
			flex-wrap: nowrap;
			align-items: center;
		}
		.blog-posts-list .blog-card .blog-card-desc {
			flex: 1 1 0;
			min-width: 0;
			-webkit-line-clamp: 2;
		}
		.blog-posts-list .blog-card .blog-card-tag-row {
			display: none;
		}
	}

	.blog-layout-menu.glass-card {
		border-radius: 0.75rem;
	}
	.blog-layout-menu {
		pointer-events: none;
		visibility: hidden;
		opacity: 0;
		transform: translateY(0.25rem) scale(0.98);
		transition:
			opacity 0.15s ease,
			transform 0.15s ease,
			visibility 0.15s;
	}
	#blog-layout-dropdown.blog-layout-is-open .blog-layout-menu {
		pointer-events: auto;
		visibility: visible;
		opacity: 1;
		transform: translateY(0) scale(1);
	}
	#blog-layout-dropdown.blog-layout-is-open .blog-layout-chevron {
		transform: rotate(180deg);
	}

	/* Explicit option hover/selected so highlight follows the pointer between items */
	.blog-layout-option {
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
	}
	.blog-layout-option:hover,
	.blog-layout-option:focus-visible {
		background-color: oklch(1 0 0 / 8%);
		color: var(--foreground);
	}
	.blog-layout-option[aria-selected='true'] {
		background-color: oklch(1 0 0 / 10%);
		color: var(--foreground);
	}
	.blog-layout-option[aria-selected='true']:hover,
	.blog-layout-option[aria-selected='true']:focus-visible {
		background-color: oklch(1 0 0 / 14%);
	}
</style>

	<script>
		import { initBlogToolbar } from '../../scripts/blog-toolbar';
		initBlogToolbar();
	</script>
</PageLayout>
