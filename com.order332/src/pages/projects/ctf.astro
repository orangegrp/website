---
import PageLayout from "../../layouts/PageLayout.astro";
---

<PageLayout
	title="CTF Platform — 332 Projects"
	description="The 332 Capture the Flag platform — accessible through Telos and at ctf.order332.com."
>
	<div class="page-root relative min-h-screen px-4 pb-32 pt-32">
		<div
			class="dot-pattern pointer-events-none absolute inset-0"
			aria-hidden="true"
		>
		</div>

		<div
			class="pointer-events-none absolute inset-0 overflow-hidden"
			aria-hidden="true"
		>
			<div
				class="absolute -right-[10%] top-[5%] h-[600px] w-[600px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.9 0 0 / 6%), transparent 65%); filter: blur(100px);"
			>
			</div>
			<div
				class="absolute -left-[5%] bottom-[10%] h-[500px] w-[500px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.8 0 0 / 5%), transparent 65%); filter: blur(80px);"
			>
			</div>
		</div>

		<div class="relative z-10 mx-auto max-w-4xl">
			<!-- Breadcrumb -->
			<nav class="mb-10" aria-label="Breadcrumb">
				<a
					href="/projects"
					class="glass-nav-link inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm tracking-wider text-muted-foreground transition-all hover:text-foreground no-underline"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-3.5 w-3.5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="m15 18-6-6 6-6"></path>
					</svg>
					All Projects
				</a>
			</nav>

			<!-- Hero -->
			<div class="mb-12 animate-[fade-in-up_0.7s_ease-out_both]">
				<div class="glass-card rounded-2xl p-8 sm:p-12">
					<div class="mb-6 flex items-start justify-between gap-4">
						<div>
							<p class="section-label">Project</p>
							<h1
								class="text-4xl tracking-wider text-foreground sm:text-5xl"
							>
								CTF Platform<span class="blink-cursor">_</span>
							</h1>
						</div>
						<span
							class="shrink-0 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs tracking-wider"
							style="background: oklch(0.65 0.15 145 / 10%); border: 1px solid oklch(0.65 0.15 145 / 30%); color: oklch(0.65 0.15 145);"
						>
							<span
								class="inline-block h-1.5 w-1.5 rounded-full"
								style="background: oklch(0.65 0.15 145); box-shadow: 0 0 4px oklch(0.65 0.15 145 / 60%);"
							></span>
							Live
						</span>
					</div>

					<p
						class="mb-6 text-base leading-relaxed text-muted-foreground sm:text-lg"
					>
						332's own CTF platform. The domain <a
							href="https://ctf.order332.com"
							target="_blank"
							rel="noopener noreferrer"
							class="text-blue-400 underline hover:text-blue-500 transition-colors"
							>ctf.order332.com</a
						> is a custom web application intentionally loaded with vulnerabilities.
						Your challenge is to find these vulnerabilities and exploit
						them! Submit your flags by messaging the Telos bot using the
						<code class="rounded bg-white/5 px-2 py-0.5 text-xs tracking-wider text-foreground">/ctf submit</code> command.
					</p>

					<div class="flex flex-wrap gap-3">
						<a
							href="https://ctf.order332.com"
							class="glass-button glass-button-glass inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm tracking-wider text-foreground no-underline transition-all"
							target="_blank"
							rel="noopener noreferrer"
						>
							ctf.order332.com
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-3.5 w-3.5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
								></path>
								<polyline points="15 3 21 3 21 9"></polyline>
								<line x1="10" y1="14" x2="21" y2="3"></line>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<!-- Related -->
			<section>
				<p class="section-label mb-4">Related</p>
				<div class="grid gap-4 sm:grid-cols-2">
					<a
						href="/projects/telos"
						class="glass-card group block rounded-2xl p-5 no-underline transition-all hover:-translate-y-0.5"
					>
						<h3 class="mb-1 text-sm tracking-wider text-foreground">
							Telos
						</h3>
						<p class="text-xs text-muted-foreground">
							Access the CTF platform through Telos
						</p>
					</a>
					<a
						href="/projects/332-labs"
						class="glass-card group block rounded-2xl p-5 no-underline transition-all hover:-translate-y-0.5"
					>
						<h3 class="mb-1 text-sm tracking-wider text-foreground">
							332 Labs
						</h3>
						<p class="text-xs text-muted-foreground">
							CTF platform will be part of 332 Labs
						</p>
					</a>
				</div>
			</section>
		</div>
	</div>

	<!-- Footer -->
	<footer class="border-t border-white/5 px-4 py-8">
		<div
			class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-4 sm:flex-row"
		>
			<div class="flex items-center gap-2.5">
				<img
					src="/polygon.svg"
					alt="332"
					class="h-5 w-5 opacity-60"
					width="20"
					height="20"
				/>
				<span class="text-sm tracking-widest text-muted-foreground"
					>332</span
				>
			</div>
			<div
				class="flex items-center gap-6 text-xs tracking-wider text-muted-foreground"
			>
				<a
					href="/"
					class="hover:text-foreground transition-colors no-underline"
					>Home</a
				>
				<a
					href="/projects"
					class="hover:text-foreground transition-colors no-underline"
					>Projects</a
				>
				<a
					href="/blog"
					class="hover:text-foreground transition-colors no-underline"
					>Blog</a
				>
			</div>
			<p class="text-xs tracking-wider text-muted-foreground opacity-40">
				© {new Date().getFullYear()} 332
			</p>
		</div>
	</footer>
</PageLayout>
