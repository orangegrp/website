---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
	title="CTF Platform — 332 Projects"
	description="The 332 Capture the Flag platform — accessible through Telos and at ctf.order332.com."
>
	<div class="page-root relative min-h-screen px-4 pb-32 pt-32">
		<div class="dot-pattern pointer-events-none absolute inset-0" aria-hidden="true"></div>

		<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
			<div
				class="absolute -right-[10%] top-[5%] h-[600px] w-[600px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.9 0 0 / 6%), transparent 65%); filter: blur(100px);"
			></div>
			<div
				class="absolute -left-[5%] bottom-[10%] h-[500px] w-[500px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.8 0 0 / 5%), transparent 65%); filter: blur(80px);"
			></div>
		</div>

		<div class="relative z-10 mx-auto max-w-4xl">

			<!-- Breadcrumb -->
			<nav class="mb-10" aria-label="Breadcrumb">
				<a
					href="/projects"
					class="glass-nav-link inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm tracking-wider text-muted-foreground transition-all hover:text-foreground no-underline"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m15 18-6-6 6-6"/>
					</svg>
					All Projects
				</a>
			</nav>

			<!-- Hero -->
			<div class="mb-12 animate-[fade-in-up_0.7s_ease-out_both]">
				<div class="glass-card rounded-2xl p-8 sm:p-12">
					<div class="mb-6 flex items-start justify-between gap-4">
						<div>
							<p class="section-label">Project</p>
							<h1 class="text-4xl tracking-wider text-foreground sm:text-5xl">
								CTF Platform<span class="blink-cursor">_</span>
							</h1>
						</div>
						<span
							class="shrink-0 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs tracking-wider"
							style="background: oklch(0.65 0.15 145 / 10%); border: 1px solid oklch(0.65 0.15 145 / 30%); color: oklch(0.65 0.15 145);"
						>
							<span class="inline-block h-1.5 w-1.5 rounded-full" style="background: oklch(0.65 0.15 145); box-shadow: 0 0 4px oklch(0.65 0.15 145 / 60%);"></span>
							Live
						</span>
					</div>

					<p class="mb-6 text-base leading-relaxed text-muted-foreground sm:text-lg">
						[A strong description of the CTF platform — what makes it interesting, who it's for (just 332 members or open to outsiders?), and what kind of challenges it hosts.]
					</p>

					<div class="flex flex-wrap gap-3">
						<a
							href="https://ctf.order332.com"
							class="glass-button glass-button-glass inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm tracking-wider text-foreground no-underline transition-all"
							target="_blank"
							rel="noopener noreferrer"
						>
							ctf.order332.com
							<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
								<polyline points="15 3 21 3 21 9"/>
								<line x1="10" y1="14" x2="21" y2="3"/>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<!-- About the platform -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Overview</p>
					<h2 class="mb-4 text-2xl tracking-wider text-foreground">The Platform<span class="blink-cursor">_</span></h2>
					<div class="space-y-4 text-sm leading-relaxed text-muted-foreground sm:text-base">
						<p>
							[Describe the CTF platform. What framework does it run on? Who can access it? Is it just for 332 members, or is it open to anyone? How do you get access?]
						</p>
						<p>
							[What kind of challenges does it host? Ongoing challenges, timed events, seasonal competitions? Are there writeups after events end?]
						</p>
					</div>
				</div>
			</section>

			<!-- Access via Telos -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Integration</p>
					<h2 class="mb-4 text-2xl tracking-wider text-foreground">Access via Telos<span class="blink-cursor">_</span></h2>
					<p class="mb-6 text-sm leading-relaxed text-muted-foreground sm:text-base">
						[Describe how the CTF platform is accessible through Telos. Commands, what they do, whether Telos can start challenges, check scores, or just provide a link.]
					</p>
					<div class="space-y-2">
						{[
							['/ctf [subcommand]', '[What the main CTF command does]'],
							['[/command]', '[Another relevant Telos → CTF command]'],
							['[/command]', '[Another relevant Telos → CTF command]'],
						].map(([cmd, desc]) => (
							<div class="flex items-start gap-4 border-b border-white/5 pb-2 last:border-0 last:pb-0">
								<code class="shrink-0 rounded bg-white/5 px-2 py-0.5 text-xs tracking-wider text-foreground">{cmd}</code>
								<span class="text-sm text-muted-foreground">{desc}</span>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Challenge categories -->
			<section class="mb-10">
				<p class="section-label mb-6">Challenge Categories</p>
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{[
						{ category: 'Web', desc: '[What web challenges look like — XSS, SQLi, SSRF, etc. Difficulty range.]' },
						{ category: 'Pwn', desc: '[Binary exploitation challenges — stack, heap, format strings, etc.]' },
						{ category: 'Reverse', desc: '[Reverse engineering challenges — binaries, firmware, obfuscated code, etc.]' },
						{ category: 'Crypto', desc: '[Cryptography challenges — classical ciphers, modern crypto, custom implementations, etc.]' },
						{ category: 'Forensics', desc: '[Forensics — disk images, memory dumps, network captures, steganography, etc.]' },
						{ category: 'OSINT', desc: '[Open source intelligence challenges — if applicable.]' },
					].map(c => (
						<div class="glass-card rounded-2xl p-5">
							<h3 class="mb-2 text-sm tracking-wider text-foreground">{c.category}</h3>
							<p class="text-xs leading-relaxed text-muted-foreground">{c.desc}</p>
						</div>
					))}
				</div>
			</section>

			<!-- Stats -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Stats</p>
					<h2 class="mb-6 text-2xl tracking-wider text-foreground">By the numbers<span class="blink-cursor">_</span></h2>
					<div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
						{[
							['[#]', 'Challenges'],
							['[#]', 'Solves'],
							['[#]', 'Players'],
							['[#]', 'Events'],
						].map(([num, label]) => (
							<div class="text-center">
								<div class="mb-1 text-3xl tracking-wider text-foreground">{num}</div>
								<div class="text-xs tracking-widest text-muted-foreground uppercase">{label}</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Technical -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Technical</p>
					<h2 class="mb-6 text-2xl tracking-wider text-foreground">Infrastructure<span class="blink-cursor">_</span></h2>
					<p class="mb-4 text-sm leading-relaxed text-muted-foreground">
						[Platform software — CTFd? Custom? What's it running on? How challenges are deployed — Docker, VMs, static files, etc. Hosting if you want to share.]
					</p>
					<div class="flex flex-wrap gap-2">
						{['[Platform]', '[Hosting]', '[Container tech]', '[Other infra]'].map(t => (
							<span class="glass-button rounded-full px-3 py-1 text-xs tracking-wider text-muted-foreground">{t}</span>
						))}
					</div>
				</div>
			</section>

			<!-- Screenshots placeholder -->
			<section class="mb-10">
				<p class="section-label mb-6">Screenshots</p>
				<div class="grid gap-4 sm:grid-cols-2">
					{[1, 2].map(n => (
						<div
							class="glass-card flex h-48 items-center justify-center rounded-2xl"
							style="border-style: dashed;"
						>
							<p class="text-xs tracking-widest text-muted-foreground uppercase">[Screenshot {n}]</p>
						</div>
					))}
				</div>
			</section>

			<!-- Related -->
			<section>
				<p class="section-label mb-4">Related</p>
				<div class="grid gap-4 sm:grid-cols-2">
					<a href="/projects/telos" class="glass-card group block rounded-2xl p-5 no-underline transition-all hover:-translate-y-0.5">
						<h3 class="mb-1 text-sm tracking-wider text-foreground">Telos</h3>
						<p class="text-xs text-muted-foreground">Access the CTF platform through Telos</p>
					</a>
					<a href="/projects/332-labs" class="glass-card group block rounded-2xl p-5 no-underline transition-all hover:-translate-y-0.5">
						<h3 class="mb-1 text-sm tracking-wider text-foreground">332 Labs</h3>
						<p class="text-xs text-muted-foreground">CTF platform will be part of 332 Labs</p>
					</a>
				</div>
			</section>

		</div>
	</div>

	<!-- Footer -->
	<footer class="border-t border-white/5 px-4 py-8">
		<div class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-4 sm:flex-row">
			<div class="flex items-center gap-2.5">
				<img src="/polygon.svg" alt="332" class="h-5 w-5 opacity-60" width="20" height="20" />
				<span class="text-sm tracking-widest text-muted-foreground">332</span>
			</div>
			<div class="flex items-center gap-6 text-xs tracking-wider text-muted-foreground">
				<a href="/" class="hover:text-foreground transition-colors no-underline">Home</a>
				<a href="/projects" class="hover:text-foreground transition-colors no-underline">Projects</a>
				<a href="/blog" class="hover:text-foreground transition-colors no-underline">Blog</a>
			</div>
			<p class="text-xs tracking-wider text-muted-foreground opacity-40">
				© {new Date().getFullYear()} 332
			</p>
		</div>
	</footer>
</PageLayout>
