---
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
	{
		name: 'Telos',
		description: 'A multifunction Discord bot with an AI assistant and smart memory system. Handles moderation, utilities, CTF access, AI conversations, and more — built specifically for 332.',
		href: '/projects/telos',
		status: 'live' as const,
		tags: ['Discord', 'AI', 'Python', 'Bot'],
	},
	{
		name: 'CTF Platform',
		description: 'Our Capture the Flag platform, accessible through Telos and directly at ctf.order332.com. Community-maintained challenges, scoreboards, and writeups.',
		href: '/projects/ctf',
		status: 'live' as const,
		tags: ['Security', 'CTF', 'Hacking', 'Web'],
	},
	{
		name: '332 Labs',
		description: 'A unified platform bringing together the CTF platform, structured courses, video and audio content, and tools for the community. Coming soon.',
		href: '/projects/332-labs',
		status: 'coming-soon' as const,
		tags: ['Platform', 'Courses', 'Media', 'Education'],
	},
	{
		name: 'TwanOS',
		description: 'A lightweight real-time separation kernel designed for adaptability, mixed-criticality workloads, and hardware-assisted virtualisation using VT-x and EPTs.',
		href: '/projects/twanos',
		status: 'active' as const,
		tags: ['Kernel', 'RTOS', 'C', 'Virtualization'],
	},
];
---

<PageLayout
	title="Projects — 332"
	description="Tools, platforms, and systems built by 332 members."
>
	<div class="page-root relative min-h-screen px-4 pb-32 pt-32">
		<div class="dot-pattern pointer-events-none absolute inset-0" aria-hidden="true"></div>

		<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
			<div
				class="absolute -left-[10%] top-[5%] h-[600px] w-[600px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.9 0 0 / 6%), transparent 65%); filter: blur(100px);"
			></div>
			<div
				class="absolute -right-[5%] bottom-[10%] h-[500px] w-[500px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.8 0 0 / 5%), transparent 65%); filter: blur(80px);"
			></div>
		</div>

		<div class="relative z-10 mx-auto max-w-4xl">

			<!-- Page header -->
			<div class="mb-16 text-center animate-[fade-in-up_0.7s_ease-out_both]">
				<p class="section-label">What We Build</p>
				<h1 class="mb-4 text-4xl tracking-wider text-foreground sm:text-5xl">
					Projects<span class="blink-cursor">_</span>
				</h1>
				<p class="mx-auto max-w-xl text-base leading-relaxed text-muted-foreground">
					Tools and systems built by members of 332. Some are in active use, some are in development, some are just getting started.
				</p>
			</div>

			<!-- Active projects -->
			<section class="mb-16">
				<p class="section-label mb-6">Active</p>
				<div class="grid gap-4 sm:grid-cols-2">
					{projects.filter(p => p.status !== 'coming-soon').map(project => (
						<ProjectCard {...project} />
					))}
				</div>
			</section>

			<!-- Coming soon -->
			<section class="mb-16">
				<p class="section-label mb-6">In Development</p>
				<div class="grid gap-4 sm:grid-cols-2">
					{projects.filter(p => p.status === 'coming-soon').map(project => (
						<ProjectCard {...project} />
					))}
				</div>
			</section>

			<!-- More coming note -->
			<section class="glass-card rounded-2xl p-8 text-center sm:p-12">
				<div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-2xl glass-button text-muted-foreground">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
				</div>
				<h2 class="mb-3 text-xl tracking-wider text-foreground">More coming<span class="blink-cursor">_</span></h2>
				<p class="mx-auto max-w-md text-sm leading-relaxed text-muted-foreground">
					[Description of what's in the pipeline — projects at early concept stage, experiments, ideas that might become something. Or just "more soon." Your call.]
				</p>
			</section>

		</div>
	</div>

	<!-- Footer -->
	<footer class="border-t border-white/5 px-4 py-8">
		<div class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-4 sm:flex-row">
			<div class="flex items-center gap-2.5">
				<img src="/polygon.svg" alt="332" class="h-5 w-5 opacity-60" width="20" height="20" />
				<span class="text-sm tracking-widest text-muted-foreground">332</span>
			</div>
			<div class="flex items-center gap-6 text-xs tracking-wider text-muted-foreground">
				<a href="/" class="hover:text-foreground transition-colors no-underline">Home</a>
				<a href="/about" class="hover:text-foreground transition-colors no-underline">About</a>
				<a href="/blog" class="hover:text-foreground transition-colors no-underline">Blog</a>
				<a href="[DISCORD_INVITE_URL]" class="hover:text-foreground transition-colors no-underline" target="_blank" rel="noopener noreferrer">Discord</a>
			</div>
			<p class="text-xs tracking-wider text-muted-foreground opacity-40">
				© {new Date().getFullYear()} 332
			</p>
		</div>
	</footer>
</PageLayout>
