---
import PageLayout from '../../layouts/PageLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
---

<PageLayout
	title="TwanOS — 332 Projects"
	description="TwanOS (Twan) is a lightweight real-time separation kernel designed for adaptability, mixed-criticality workloads, and hardware-assisted virtualisation."
>
	<div class="page-root relative min-h-screen px-4 pb-32 pt-32">
		<div class="dot-pattern pointer-events-none absolute inset-0" aria-hidden="true"></div>

		<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
			<div
				class="absolute -left-[10%] top-[5%] h-[600px] w-[600px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.9 0 0 / 6%), transparent 65%); filter: blur(100px);"
			></div>
			<div
				class="absolute -right-[5%] bottom-[10%] h-[500px] w-[500px] rounded-full"
				style="background: radial-gradient(circle, oklch(0.8 0 0 / 5%), transparent 65%); filter: blur(80px);"
			></div>
		</div>

		<div class="relative z-10 mx-auto max-w-4xl">

			<!-- Breadcrumb -->
			<nav class="mb-10" aria-label="Breadcrumb">
				<a
					href="/projects"
					class="glass-nav-link inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm tracking-wider text-muted-foreground transition-all hover:text-foreground no-underline"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m15 18-6-6 6-6"/>
					</svg>
					All Projects
				</a>
			</nav>

			<!-- Hero -->
			<div class="mb-12 animate-[fade-in-up_0.7s_ease-out_both]">
				<div class="glass-card rounded-2xl p-8 sm:p-12">
					<div class="mb-6 flex items-start justify-between gap-4">
						<div>
							<p class="section-label">Project · Member Built</p>
							<h1 class="text-4xl tracking-wider text-foreground sm:text-5xl">
								TwanOS<span class="blink-cursor">_</span>
							</h1>
						</div>
						<span
							class="shrink-0 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs tracking-wider"
							style="background: oklch(0.65 0.15 145 / 10%); border: 1px solid oklch(0.65 0.15 145 / 30%); color: oklch(0.65 0.15 145);"
						>
							<span class="inline-block h-1.5 w-1.5 rounded-full" style="background: oklch(0.65 0.15 145); box-shadow: 0 0 4px oklch(0.65 0.15 145 / 60%);"></span>
							Active
						</span>
					</div>

					<p class="mb-6 text-base leading-relaxed text-muted-foreground sm:text-lg">
						A lightweight separation kernel designed for adaptability, real-time computing, and mixed-criticality workloads. Built from scratch by a 332 member.
					</p>

					<div class="flex flex-wrap gap-3">
						<a
							href="https://github.com/MicroOperations/Twan"
							class="glass-button glass-button-glass inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm tracking-wider text-foreground no-underline transition-all"
							target="_blank"
							rel="noopener noreferrer"
						>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
							</svg>
							GitHub
						</a>
					</div>
				</div>
			</div>

			<!-- Overview -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Overview</p>
					<h2 class="mb-4 text-2xl tracking-wider text-foreground">What it is<span class="blink-cursor">_</span></h2>
					<div class="space-y-4 text-sm leading-relaxed text-muted-foreground sm:text-base">
						<p>
							Twan is intended to serve as foundational infrastructure for building specialized systems — not a complete end-user environment.
							It is designed to be adapted and extended for specific deployment requirements.
						</p>
						<p>
							It is currently in early-stage development with support for Intel processors with VT-x, EPTs, and unrestricted guest mode.
							Twan is not currently ARINC 653 or SKPP compliant out of the box — certification requires formal verification and safety analysis beyond the current scope.
						</p>
					</div>
				</div>
			</section>

			<!-- Architecture -->
			<section class="mb-10">
				<p class="section-label mb-6">Architecture</p>
				<div class="grid gap-4 sm:grid-cols-2">
					<div class="glass-card rounded-2xl p-6">
						<h3 class="mb-3 text-base tracking-wider text-foreground">Twanvisor</h3>
						<p class="text-sm leading-relaxed text-muted-foreground">
							A hypervisor that leverages hardware-assisted virtualisation to isolate partitions.
							Guests are paravirtualised and use APIs provided by Twanvisor.
						</p>
					</div>
					<div class="glass-card rounded-2xl p-6">
						<h3 class="mb-3 text-base tracking-wider text-foreground">TwanRTOS</h3>
						<p class="text-sm leading-relaxed text-muted-foreground">
							The trusted root partition operating system that acts as the system orchestrator.
							Initializes Twanvisor, controls partition policies, and serves as the central manager for hardware and system resources.
						</p>
					</div>
				</div>
			</section>

			<!-- Hardware support & features -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Hardware Support</p>
					<h2 class="mb-6 text-2xl tracking-wider text-foreground">Requirements<span class="blink-cursor">_</span></h2>

					<p class="mb-4 text-sm text-muted-foreground">
						Currently supports Intel processors with:
					</p>

					<div class="mb-6 grid gap-3 sm:grid-cols-3">
						{[
							{ label: 'VT-x', desc: 'Intel Virtualization Technology for IA-32, Intel 64 and Intel Architecture' },
							{ label: 'EPTs', desc: 'Extended Page Tables — second-level address translation for guests' },
							{ label: 'Unrestricted Guest', desc: 'Supports real-mode and big real-mode guest execution' },
						].map(item => (
							<div class="glass-card rounded-xl p-4">
								<code class="mb-2 block text-sm tracking-wider text-foreground">{item.label}</code>
								<p class="text-xs leading-relaxed text-muted-foreground">{item.desc}</p>
							</div>
						))}
					</div>

					<p class="text-xs text-muted-foreground opacity-70">
						Note: Even if your hardware meets these requirements, it may not work out of the box. The project is in early development.
					</p>
				</div>
			</section>

			<!-- Design goals -->
			<section class="mb-10">
				<p class="section-label mb-6">Design Goals</p>
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{[
						{ label: 'Adaptability', desc: 'Designed to be adapted and extended for specific deployment requirements — not a fixed monolithic system.' },
						{ label: 'Real-Time', desc: 'Built for real-time computing — deterministic execution, predictable timing, suitable for time-critical workloads.' },
						{ label: 'Mixed-Criticality', desc: 'Supports mixed-criticality systems — isolating high-criticality tasks from lower-criticality ones within the same hardware.' },
						{ label: 'Separation', desc: 'Enforces strong separation between partitions — hardware-level isolation via virtualisation technology.' },
						{ label: 'Lightweight', desc: 'Minimal footprint by design — kernel code in C and assembly, focused on doing the separation job and nothing more.' },
						{ label: 'Open Source', desc: 'Licensed under MIT. Source on GitHub. Contributions welcome — see the repo for current status.' },
					].map(g => (
						<div class="glass-card rounded-2xl p-5">
							<h3 class="mb-2 text-sm tracking-wider text-foreground">{g.label}</h3>
							<p class="text-xs leading-relaxed text-muted-foreground">{g.desc}</p>
						</div>
					))}
				</div>
			</section>

			<!-- Tech details -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Technical</p>
					<h2 class="mb-6 text-2xl tracking-wider text-foreground">Stack & Dependencies<span class="blink-cursor">_</span></h2>

					<div class="mb-6 flex flex-wrap gap-2">
						{['C (97.7%)', 'Assembly (1.8%)', 'uACPI', 'nanoprintf', 'Concurrency Kit', 'GRUB', 'Kconfig', 'MIT License'].map(t => (
							<span class="glass-button rounded-full px-3 py-1 text-xs tracking-wider text-muted-foreground">{t}</span>
						))}
					</div>

					<p class="text-sm leading-relaxed text-muted-foreground">
						<strong class="text-foreground">References:</strong>{' '}
						Muen, L4re/Fiasco, Composite, cmrx, Nova, Xen, POK, XtratuM, Deos, EURO-MILS MILS Architecture Whitepaper, Separation Kernel Protection Profile.
					</p>
				</div>
			</section>

			<!-- Status -->
			<section class="mb-10">
				<div class="glass-card rounded-2xl p-8 sm:p-10">
					<p class="section-label">Status</p>
					<h2 class="mb-4 text-2xl tracking-wider text-foreground">Development<span class="blink-cursor">_</span></h2>
					<p class="text-sm leading-relaxed text-muted-foreground sm:text-base">
						Twan is in early development. It is not production-ready. If you want to follow along, track issues, or contribute, the GitHub repository is the right place.
					</p>
					<div class="mt-6">
						<a
							href="https://github.com/MicroOperations/Twan"
							class="glass-button glass-button-glass inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm tracking-wider text-foreground no-underline transition-all"
							target="_blank"
							rel="noopener noreferrer"
						>
							View on GitHub
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
								<polyline points="15 3 21 3 21 9"/>
								<line x1="10" y1="14" x2="21" y2="3"/>
							</svg>
						</a>
					</div>
				</div>
			</section>

		</div>
	</div>

	<!-- Footer -->
	<SiteFooter />
</PageLayout>
