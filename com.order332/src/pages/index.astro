---
import { getCollection } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/Hero.astro";
import BlogCard from "../components/BlogCard.astro";
import SiteFooter from "../components/SiteFooter.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = posts
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<PageLayout
	title="332"
	description="332 — invite-only Discord community since 2020. Read member posts or find out why it still smells like IRC with better audio."
>
	<!-- Hero -->
	<Hero />

	<!-- About section -->
	<section class="relative overflow-hidden px-4 py-24">
		<div
			class="dot-pattern pointer-events-none absolute inset-0 opacity-40"
			aria-hidden="true"
		>
		</div>
		<div class="relative z-10 mx-auto max-w-4xl">
			<div class="mb-10 text-center">
				<h2 class="text-2xl tracking-wider text-foreground sm:text-3xl">
					About us
				</h2>
				<p
					class="mx-auto mt-3 max-w-lg text-sm text-muted-foreground sm:text-base"
				>
					Same origin story wherever you skim it—we just lead with
					visuals here.
				</p>
			</div>

			<div
				style="width:100%;max-width:960px;aspect-ratio:7/3;border-radius:24px;overflow:hidden; border-bottom: 1px solid var(--glass-border-subtle);"
				class="mb-16"
			>
				<iframe
					src="https://app.order332.com/share/-yCgMBOvrHb-MQ-mC553jfYsinX8ptlnzjW0xEw0DRM/embed"
					title="332 Trailer"
					loading="lazy"
					allow="autoplay; fullscreen; picture-in-picture"
					referrerpolicy="no-referrer"
					style="width:100%;height:100%;border:0;overflow:hidden;scrollbar-width:none;-ms-overflow-style:none;"
					scrolling="no"></iframe>
			</div>
		</div>
	</section>

	<!-- Blog section -->
	{
		latestPosts.length > 0 && (
			<section class="relative overflow-hidden px-4 py-24">
				<div
					class="dot-pattern pointer-events-none absolute inset-0 opacity-30"
					aria-hidden="true"
				/>
				<div class="relative z-10 mx-auto max-w-4xl">
					<div class="mb-10 flex items-end justify-between gap-4">
						<div>
							<h2 class="text-2xl tracking-wider text-foreground sm:text-3xl">
								Latest from the blog
							</h2>
						</div>
						<a
							href="/blog"
							class="glass-nav-link shrink-0 rounded-lg px-3 py-1.5 text-sm tracking-wider text-muted-foreground no-underline transition-all hover:text-foreground"
						>
							All posts →
						</a>
					</div>

					<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{latestPosts.map((post) => (
							<BlogCard
								title={post.data.title}
								description={post.data.description}
								date={post.data.date}
								slug={post.id}
								author={post.data.author}
								tags={post.data.tags}
							/>
						))}
					</div>
				</div>
			</section>
		)
	}

	<!-- Join CTA section -->
	<section class="relative overflow-hidden px-4 py-32">
		<div class="pointer-events-none absolute inset-0" aria-hidden="true">
			<div
				class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full"
				style="background: radial-gradient(circle, oklch(0.9 0 0 / 6%), transparent 60%); filter: blur(80px);"
			>
			</div>
		</div>

		<div class="relative z-10 mx-auto max-w-2xl text-center">
			<h2
				class="mb-4 text-2xl tracking-wider text-foreground sm:text-3xl"
			>
				Invite-only community
			</h2>
			<p
				class="mb-8 text-sm leading-relaxed text-muted-foreground sm:text-base"
			>
				332 is a private community. If you've been invited—or know
				someone who can vouch for you—use the link below to join. If you
				don't have an invite but are interested in joining, you can also
				apply using the same link.
			</p>

			<div class="flex flex-wrap items-center justify-center gap-4">
				<a
					href="https://discord.gg/WuGrkMZeNG"
					class="glass-button glass-button-glass inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm tracking-wider text-foreground no-underline transition-all"
					target="_blank"
					rel="noopener noreferrer"
				>
					Join on Discord
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path
							d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
						></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
				</a>
				<a
					href="/about"
					class="glass-button inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm tracking-wider text-muted-foreground no-underline transition-all hover:text-foreground"
				>
					Learn more
				</a>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<SiteFooter />
</PageLayout>
