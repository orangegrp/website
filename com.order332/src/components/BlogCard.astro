---
interface Props {
	title: string;
	description: string;
	date: Date;
	slug: string;
	author?: string;
	tags?: string[];
}

const { title, description, date, slug, author = '332', tags = [] } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
}).format(date);
---

<a
	href={`/blog/${slug}`}
	class="blog-card glass-card group block rounded-2xl p-6 no-underline transition-all duration-300 hover:-translate-y-0.5"
>
	<div class="mb-3 flex items-center gap-3 text-xs tracking-widest text-muted-foreground uppercase">
		<time datetime={date.toISOString()}>{formattedDate}</time>
		{author && (
			<>
				<span class="opacity-30">·</span>
				<span>{author}</span>
			</>
		)}
	</div>

	<h3 class="mb-2 text-lg leading-snug tracking-wider text-foreground transition-colors group-hover:text-foreground">
		{title}
	</h3>

	<p class="blog-card-desc mb-4 text-sm leading-relaxed text-muted-foreground line-clamp-2">
		{description}
	</p>

	{tags.length > 0 && (
		<div class="blog-card-tag-row mb-4 flex flex-wrap gap-1.5">
			{tags.slice(0, 3).map(tag => (
				<span class="glass-button rounded-full px-2.5 py-0.5 text-xs tracking-wider text-muted-foreground">
					{tag}
				</span>
			))}
		</div>
	)}

	<div class="blog-card-read flex items-center gap-1.5 text-xs tracking-widest text-muted-foreground uppercase transition-colors group-hover:text-foreground">
		Read post
		<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m9 18 6-6-6-6"/>
		</svg>
	</div>
</a>

<style>
	.blog-card:hover {
		background: oklch(1 0 0 / 5%);
	}
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
