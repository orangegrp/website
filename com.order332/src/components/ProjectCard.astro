---
interface Props {
	name: string;
	description: string;
	href: string;
	status?: 'live' | 'beta' | 'coming-soon' | 'active';
	externalLink?: boolean;
	tags?: string[];
}

const {
	name,
	description,
	href,
	status = 'active',
	externalLink = false,
	tags = [],
} = Astro.props;

const statusConfig = {
	live: { label: 'Live', color: 'oklch(0.65 0.15 145)' },
	beta: { label: 'Beta', color: 'oklch(0.65 0.15 250)' },
	'coming-soon': { label: 'Coming Soon', color: 'oklch(0.65 0.12 70)' },
	active: { label: 'Active', color: 'oklch(0.65 0.15 145)' },
};

const badge = statusConfig[status];
---

<a
	href={href}
	target={externalLink ? '_blank' : undefined}
	rel={externalLink ? 'noopener noreferrer' : undefined}
	class="project-card glass-card group block rounded-2xl p-6 no-underline transition-all duration-300 hover:-translate-y-0.5"
>
	<div class="mb-4 flex items-start justify-between gap-3">
		<h3 class="text-lg tracking-wider text-foreground leading-snug">{name}</h3>
		<span
			class="shrink-0 inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs tracking-wider"
			style={`background: ${badge.color}18; border: 1px solid ${badge.color}35; color: ${badge.color};`}
		>
			<span
				class="inline-block h-1.5 w-1.5 rounded-full"
				style={`background: ${badge.color}; box-shadow: 0 0 4px ${badge.color}70;`}
			></span>
			{badge.label}
		</span>
	</div>

	<p class="mb-5 text-sm leading-relaxed text-muted-foreground">{description}</p>

	{tags.length > 0 && (
		<div class="mb-5 flex flex-wrap gap-1.5">
			{tags.map(tag => (
				<span class="glass-button rounded-full px-2.5 py-0.5 text-xs tracking-wider text-muted-foreground">
					{tag}
				</span>
			))}
		</div>
	)}

	<div class="flex items-center gap-1.5 text-xs tracking-widest text-muted-foreground uppercase transition-colors group-hover:text-foreground">
		{externalLink ? 'View on GitHub' : 'Learn more'}
		<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			{externalLink
				? <><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></>
				: <path d="m9 18 6-6-6-6"/>
			}
		</svg>
	</div>
</a>

<style>
	.project-card:hover {
		background: oklch(1 0 0 / 5%);
	}
</style>
