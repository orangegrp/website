---
---

<section
	class="page-root relative flex min-h-screen items-center justify-center overflow-clip px-4 pt-24"
>
	<div
		class="dot-pattern pointer-events-none absolute inset-0"
		aria-hidden="true"
	></div>

	<div class="pointer-events-none absolute inset-0" aria-hidden="true" style="contain: layout style paint;">
		<div
			class="absolute -left-[10%] -top-[10%] h-[700px] w-[700px] rounded-full"
			style="background: radial-gradient(circle, oklch(0.9 0 0 / 8%), transparent 65%); animation: float-orb-1 28s ease-in-out infinite; filter: blur(100px); will-change: transform;"
		></div>
		<div
			class="absolute -right-[5%] top-[20%] h-[800px] w-[800px] rounded-full"
			style="background: radial-gradient(circle, oklch(0.8 0 0 / 6%), transparent 65%); animation: float-orb-2 34s ease-in-out infinite; filter: blur(120px); will-change: transform;"
		></div>
		<div
			class="absolute bottom-[5%] left-[30%] h-[650px] w-[650px] rounded-full"
			style="background: radial-gradient(circle, oklch(0.85 0 0 / 7%), transparent 65%); animation: float-orb-3 24s ease-in-out infinite; filter: blur(110px); will-change: transform;"
		></div>
	</div>

	<div
		class="relative z-10 mx-auto flex max-w-3xl flex-col items-center gap-8 text-center animate-[fade-in-up_0.8s_ease-out_both]"
	>
		<div
			class="relative z-10 mx-4 flex max-w-2xl flex-col items-center gap-8 px-8 py-14 text-center sm:px-16 sm:py-20"
		>
			<img
				src="/polygon.svg"
				alt="332"
				class="h-20 w-20 sm:h-24 sm:w-24"
				fetchpriority="high"
				width="96"
				height="96"
				style="filter: drop-shadow(0 0 16px oklch(1 0 0 / 15%));"
			/>

			<div class="flex flex-col items-center gap-4">
				<div class="flex items-center gap-2 text-xs tracking-widest text-muted-foreground uppercase">
					<span id="days-active"></span>
					<script is:inline>
						const startedAt = new Date(Date.UTC(2020, 8, 6));
						const msPerDay = 1000 * 60 * 60 * 24;
						const now = new Date();
						const diffDays = Math.floor((now.getTime() - startedAt.getTime()) / msPerDay);
						const el = document.getElementById('days-active');
						if (el) el.textContent = `Active for ${diffDays} days`;
					</script>
					<span class="opacity-30">·</span>
					<span>EST. 2020</span>
				</div>

				<h1 class="text-3xl leading-snug tracking-wider text-foreground sm:text-4xl md:text-5xl">
					332<span class="blink-cursor">_</span>
				</h1>

				<p class="max-w-md text-sm leading-relaxed text-muted-foreground sm:text-base">
					Community. Knowledge. Friendship.
				</p>
			</div>

			<p class="max-w-lg text-sm leading-relaxed text-muted-foreground">
				Welcome to 332: Discord's best invite-only hub for all things cybersecurity, gaming and unrivalled freedom. Keep scrolling to learn more about what you're missing out on.
			</p>

			<div class="flex flex-wrap items-center justify-center gap-3">
				<a
					href="/projects"
					class="glass-button glass-button-glass inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm tracking-wider text-foreground no-underline transition-all"
				>
					Explore Projects
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m9 18 6-6-6-6"/>
					</svg>
				</a>
				<a
					href="/blog"
					class="glass-button inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm tracking-wider text-muted-foreground no-underline transition-all hover:text-foreground"
				>
					Read the Blog
				</a>
			</div>
		</div>

		<!-- Scroll indicator -->
		<div
			class="flex flex-col items-center gap-2 text-xs tracking-widest uppercase opacity-40"
			aria-hidden="true"
		>
			<span>Scroll</span>
			<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="m6 9 6 6 6-6"/>
			</svg>
		</div>
	</div>
</section>
